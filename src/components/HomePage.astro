---
/**
 * The full homepage (left column + projects + styles + scripts), shared by the
 * English (/) and German (/de/) versions. All visible text comes in via `t`,
 * so the two languages can never drift apart in design — edit markup/styles
 * here once and both pages update.
 */
import Projects from './Projects.astro'
import Testimonials from './Testimonials.astro'
import ReachOutForm from './ReachOutForm'
import { Image } from 'astro:assets';
import xSVG from '../../public/x.svg'
import mePFP from '../images/me.jpg'

export interface HomeStrings {
	badge: string;
	headline: string;
	subheadline: string;
	ctaLabel: string;
	xLabel: string;
	nav: { email: string; cal: string; telegram: string };
	footer: {
		imprint: string;
		privacy: string;
		photography: string;
	};
}

interface Props {
	t: HomeStrings;
	lang: 'en' | 'de';
}

const { t, lang } = Astro.props;

const xHref = 'https://x.com/denizdoingstuff';
---

<div class="container">
	<div class="content-wrapper">
		<div class="left-column">

			<header class="hero-header">
				<div class="nav-row">
					<a href={lang === 'de' ? '/de/' : '/'} class="site-logo">deniz.studio</a>
					<nav class="nav-links">
						<span class="nav-link email-link" id="nav-email">
							{t.nav.email}
							<span class="email-tooltip">mail@deniz.studio</span>
						</span>
						<a class="nav-link" id="nav-cal" href="https://cal.com/denizkumral/intro" target="_blank">{t.nav.cal}</a>

						<a class="nav-link" id="nav-telegram" href="https://t.me/denizdoingstuff" target="_blank">{t.nav.telegram}</a>
					</nav>
				</div>
			</header>

			<div class="main">
				<div class="title-cta">
					<div class="titletext">
						<div class="headline-wrap">
							<div class="limited-badge">{t.badge}</div>
							<h1 class="hero-headline">{t.headline}</h1>
						</div>
						<div class="subheadline-wrap">
							<p class="hero-subheadline">{t.subheadline}</p>
						</div>
					</div>
					<div class="buttons">
						<div class="buttons-inner">
							<div class="cta-col">
								<button class="cta" id="reachOutBtn">
									<Image quality={100} src={mePFP} class="cta-pfp" alt="Deniz" width={200} height={200}/>
									<div class="cta-label">{t.ctaLabel}</div>
								</button>
							</div>
							<a
								class="cta-case-study"
								href={xHref}
								target="_blank"
								rel="noopener noreferrer"
								id="xBtn"
							>
								<Image quality={100} src={xSVG} class="x-icon" alt="" width={24} height={24}/>
								<span>{t.xLabel}</span>
							</a>
						</div>
					</div>
				</div>
				<div class="reachout-slot">
					<ReachOutForm client:load lang={lang} />
				</div>
			</div>

			<div class="bottom-content">
				<Testimonials />
				<div class="links">
					<a href="/imprint">{t.footer.imprint}</a>
					<a href="/privacy">{t.footer.privacy}</a>
					<a href="https://photo.deniz.studio" target="_blank">{t.footer.photography}</a>
				</div>
			</div>

		</div>

		<div class="right-column">
			<Projects />
		</div>
	</div>
</div>

<div class="mobile-links">
	<div class="links">
		<a href="/imprint">{t.footer.imprint}</a>
		<a href="/privacy">{t.footer.privacy}</a>
		<a href="https://photo.deniz.studio" target="_blank">{t.footer.photography}</a>
	</div>
</div>

<script is:inline
	src="https://cdn.databuddy.cc/databuddy.js"
	data-client-id="u3DUg2DzSoaD6s6Oloc8e"
	data-track-hash-changes="true"
	data-track-attributes="true"
	data-track-outgoing-links="true"
	data-track-interactions="true"
	data-track-engagement="true"
	data-track-scroll-depth="true"
	data-track-exit-intent="true"
	data-track-bounce-rate="true"
	data-track-web-vitals="true"
	data-track-errors="true"
	data-enable-batching="true"
	crossorigin="anonymous"
	async
></script>
<script is:inline>
	const track = async (eventName, properties) => {
		if (typeof window === 'undefined') return;
		const tracker = window.db?.track || window.databuddy?.track;
		if (!tracker) return;
		try { await tracker(eventName, properties); } catch (e) {
			console.log('Tracking: Failed to send event', e.message);
		}
	};

	document.addEventListener('DOMContentLoaded', function() {
		const navEmail = document.getElementById('nav-email');
		if (navEmail) {
			navEmail.addEventListener('click', function() {
				track('mail_clicked', {
					timestamp: new Date().toISOString(),
					page: window.location.pathname
				});
				window.location.href = 'mailto:mail@deniz.studio';
			});
		}

		const navTelegram = document.getElementById('nav-telegram');
		if (navTelegram) {
			navTelegram.addEventListener('click', function() {
				track('telegram_clicked', {
					url: 'https://t.me/denizdoingstuff',
					timestamp: new Date().toISOString(),
					page: window.location.pathname
				});
			});
		}

		const xBtn = document.getElementById('xBtn');
		if (xBtn) {
			xBtn.addEventListener('click', function() {
				track('twitter_clicked', {
					url: 'https://x.com/denizdoingstuff',
					timestamp: new Date().toISOString(),
					page: window.location.pathname
				});
			});
		}
	});
</script>

<style is:global>
	@font-face {
		font-family: 'General Sans';
		src: url('/fonts/GeneralSans-Variable.ttf') format('truetype');
		font-weight: 200 700;
		font-style: normal;
		font-display: swap;
	}

*, *::before, *::after {
  box-sizing: border-box;
  font-family: "General Sans", sans-serif;
}

* {
  margin: 0;
}

@media (prefers-reduced-motion: no-preference) {
  html {
    interpolate-size: allow-keywords;
  }
}

html {
  /* The site is light-only. Declaring this stops browsers (and Chrome's Auto
     Dark Mode) from force-darkening the page for dark-mode users. */
  color-scheme: light;
  background-color: #ffffff;
}

body {
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: #ffffff;
}

img, picture, video, canvas, svg {
  display: block;
  max-width: 100%;
}

input, button, textarea, select {
  font: inherit;
}

a {
  color: inherit;
  font-size: 14px;
}

p, h1, h2, h3, h4, h5, h6 {
  overflow-wrap: break-word;
}

p {
  text-wrap: pretty;
  color: #1e1e1e;
}

h1, h2, h3, h4, h5, h6 {
  text-wrap: balance;
  color: #1e1e1e;
}

#root, #__next {
  isolation: isolate;
}

.container {
  width: 100%;
  max-width: none;
  margin: 0;
  padding: 0;
  min-height: 100vh;
}

.content-wrapper {
  display: flex;
  width: 100%;
  margin: 0;
  padding: 0;
  min-height: 100vh;
}

.left-column {
  width:  640px;
  flex-shrink: 0;
  padding: 28px 10px 28px 14px;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
}

.hero-header {
  width: 100%;
  flex-shrink: 0;
}

.nav-row {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 30px;
  width: 100%;
  padding-left: 24px;
  padding-right: 24px;
}

.nav-links {
  display: flex;
  align-items: start;
  gap: 24px;
}

.nav-link {
  font-size: 14px;
  font-weight: 450;
  line-height: 18px;
  color: #000000;
  cursor: pointer;
  text-decoration: none;
  background: none;
  border: none;
  padding: 0;
  transition: color 0.15s ease-in-out;
}

.nav-link:hover {
  color: #7a7a7a;
}

.email-link {
  position: relative;
}

.email-tooltip {
  position: absolute;
  left: 50%;
  top: 100%;
  transform: translateX(-50%);
  margin-top: 6px;
  padding: 6px 10px;
  font-size: 12px;
  line-height: 1.2;
  white-space: nowrap;
  color: #1e1e1e;
  background-color: #ffffff;
  border: 1px solid rgba(30, 30, 30, 0.14);
  border-radius: 6px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.15s ease, visibility 0.15s ease;
  z-index: 10;
}

.email-link:hover .email-tooltip {
  opacity: 1;
  visibility: visible;
}

.site-logo {
  flex: 1;
  font-size: 16px;
  font-weight: 520;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: #1e1e1e;
  text-decoration: none;
  transition: color 0.15s ease-in-out;
}

.site-logo:hover {
  color: #7a7a7a;
}

.main {
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 100%;
  min-height: 0;
}

.title-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
  width: 100%;
}

/* When the inline form is open, keep the column scroll-safe: never let .main
   shrink below the form's height (which would clip the top under justify-content:
   center). It still grows to vertically center the form on tall viewports. */
.main.reachout-open {
  flex: 1 0 auto;
}

.reachout-slot {
  width: 100%;
  padding: 0 24px;
}

.reachout-slot astro-island {
  display: block;
  width: 100%;
}

.titletext {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  width: 100%;
}

.limited-badge {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  color: #888;
  margin-bottom: 6px
}

@keyframes pulse-ring {
  0%, 100% { box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.5); }
  50% { box-shadow: 0 0 0 3px rgba(74, 222, 128, 0); }
}

.limited-badge::before {
  content: "";
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #4ade80;
  animation: pulse-ring 2s ease-in-out infinite;
  flex-shrink: 0;
}

.headline-wrap {
  padding-bottom: 6px;
}

.headline-wrap {
  padding-bottom: 2.8px;
}

.hero-headline {
  font-size: 28px;
  font-weight: 550;
  line-height: 1.3;
  letter-spacing: -0.02em;
  text-align: center;
  text-wrap: nowrap;
  white-space: nowrap;
  color: #1e1e1e;
}

.subheadline-wrap {
  max-width: 420px;
}

.hero-subheadline {
  font-size: 15px;
  font-weight: 450;
  line-height: 1.55;
  text-align: center;
  text-wrap: pretty;
  color: #1e1e1e;
}

.buttons {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 12px;
  width: 100%;
}

.buttons-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 8px;
  width: 100%;
}

.cta-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: fit-content;
  background-color: #1e1e1e;
  color: #ffffff;
  padding: 6px 16px 6px 6px;
  border-radius: 100px;
  border: 1px solid rgba(0, 0, 0, 0.05);
  box-shadow: inset 0px -1px 12.4px -4px rgba(255, 255, 255, 0.75);
  cursor: pointer;
  transition: background-color 0.15s ease-in-out, border-color 0.15s ease-in-out;
}

.cta:hover {
  background-color: #333333;
  border-color: rgba(0, 0, 0, 0.05);
}

.cta-label {
  font-size: 14px;
  font-weight: 500;
  line-height: 1.5;
  color: #ffffff;
}

.cta-pfp {
  width: 28px;
  height: 28px;
  border-radius: 100px;
  flex-shrink: 0;
  object-fit: cover;
}

.cta-case-study {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: stretch;
  gap: 8px;
  flex-shrink: 0;
  background-color: #ffffff;
  color: #1e1e1e;
  padding: 8px 14px 8px 16px;
  border-radius: 100px;
  border: 1px solid rgba(30, 30, 30, 0.14);
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  text-decoration: none;
  font-weight: 500;
  font-size: 14px;
  line-height: 1.2;
  white-space: nowrap;
  transition: background-color 0.15s ease-in-out, border-color 0.15s ease-in-out, color 0.15s ease-in-out;
}

.cta-case-study:hover {
  color: #1e1e1e;
  background-color: #fafafa;
  border-color: rgba(30, 30, 30, 0.22);
}

.cta-case-study:focus-visible {
  outline: 2px solid #1e1e1e;
  outline-offset: 2px;
}

.x-icon {
  width: 14px;
  height: auto;
  flex-shrink: 0;
}

.bottom-content {
  flex-shrink: 0;
  width: 100%;
  padding-top: 16px;
}

.links {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
  margin-top: 22px;
  max-width: 650px;
  opacity: 0.6;
  width: 100%;
  padding-left: 22px;
  padding-right: 22px;
}

.links a {
  font-size: 10px;
  font-weight: 400;
  line-height: 1.3;
  color: #000000;
  text-decoration: underline;
  text-underline-offset: auto;
}

.links a:hover {
  color: #7a7a7a;
}

.right-column {
  flex: 1;
  min-width: 0;
  padding: 28px 22px 0 22px;
  margin: 0;
  width: 100%;
  max-width: 100%;
  overflow-x: visible;
  box-sizing: border-box;
}

.right-column .projects {
  margin: 0;
  padding: 0;
  width: 100%;
  max-width: 100%;
  display: block;
}

.projects {
  width: 100%;
  height: 100%;
}

.mobile-links {
  display: none;
}

@media (max-width: 1023px) {
  body {
    justify-content: flex-start;
    align-items: stretch;
  }

  .content-wrapper {
    flex-direction: column;
  }

  .left-column {
    width: 100%;
    height: auto;
    min-height: 0;
    position: static;
    padding: 24px 16px;
    overflow-y: visible;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0;
  }

  .hero-header {
    margin-bottom: 32px;
  }

  .nav-links {
    gap: 14px;
  }

  .nav-row {
    padding: 0 4px;
  }

  .nav-link {
    font-size: 14px;
  }

  .main {
    flex: 0 0 auto;
    display: block;
    justify-content: flex-start;
    min-height: 0;
    margin-bottom: 8px;
  }

  .reachout-slot {
    padding: 0 4px;
  }

  .bottom-content {
    padding-top: 32px;
    margin-top: 0;
    width: 100%;
  }

  .title-cta {
    align-items: stretch;
    gap: 24px;
  }

  .titletext {
    align-items: center;
    text-align: center;
    gap: 10px;
  }

  .headline-wrap {
    padding-bottom: 0;
  }

  .hero-headline {
    padding-bottom: 0;
    margin-bottom: 0;
    margin-top: 0;
    white-space: normal;
    text-wrap: pretty;
  }

  .subheadline-wrap {
    max-width: none;
  }

  .hero-subheadline {
    text-align: center;
    max-width: 420px;
    line-height: 1.4;
    text-wrap: balance;
  }

  .buttons {
    align-items: center;
    justify-content: center;
  }

  .buttons-inner {
    flex-direction: row;
    align-items: center;
    gap: 8px;
    justify-content: center;
  }

  .cta-col {
    width: auto;
    align-items: center;
  }

  .cta-case-study {
    white-space: nowrap;
  }

  .right-column {
    padding: 0 16px 24px;
    margin-top: 24px;
  }

  .left-column .links {
    display: none;
  }

  .mobile-links {
    display: block;
    width: 100%;
    padding: 0 16px 40px;
    text-align: center;
  }

  .mobile-links .links {
    justify-content: center;
    margin: 0;
    padding: 0;
  }

}

@media (max-width: 480px) {
  .left-column {
    padding: 18px 14px;
  }

  .nav-row {
    gap: 14px;
  }

  .nav-links {
    gap: 10px;
  }

  .nav-link {
    font-size: 13px;
  }

  .buttons {
    align-items: center;
    gap: 8px;
  }

  .hero-subheadline {
    max-width: 320px;
  }

  .links {
    gap: 12px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .email-tooltip {
    transition: none;
  }
}
</style>
