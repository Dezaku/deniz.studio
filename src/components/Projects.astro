---
import { Picture, getImage } from 'astro:assets';
import { projects } from '../data/projects';

/*
 * Right-column case studies. Each project is a folder under src/images/projects/
 * whose files are numbered by display order. WHICH projects show, in WHAT order,
 * and their headlines are controlled entirely in src/data/projects.ts.
 *
 * Inside a project folder:
 *   - Static image  ->  1.png / 2.jpg / 3.webp   (auto AVIF+WebP, responsive, lazy)
 *   - Animated clip ->  6.webm + 6.mp4, with 6.png as its poster (same number = poster)
 *   - A bare 6.gif also works (plays as-is) — ask me to encode it to video for speed.
 *   - Optional alt label: "3-features.png" -> alt "features".
 */

// Eager-glob every media file across all project folders (patterns are static literals).
const imageMods = import.meta.glob('../images/projects/*/*.{png,jpg,jpeg,webp,avif}', { eager: true, import: 'default' });
const gifMods   = import.meta.glob('../images/projects/*/*.gif',                        { eager: true, import: 'default' });
const videoMods = import.meta.glob('../images/projects/*/*.{mp4,webm}',                 { eager: true, import: 'default' });

const folderOf = (p) => p.split('/images/projects/')[1].split('/')[0];
const baseOf   = (p) => p.split('/').pop().replace(/\.[^.]+$/, '');
const numOf    = (p) => { const m = baseOf(p).match(/^(\d+)/); return m ? parseInt(m[1], 10) : Number.POSITIVE_INFINITY; };
const labelOf  = (p) => baseOf(p).replace(/^\d+[-_ ]*/, '').replace(/[-_]+/g, ' ').trim();
const titleCase = (s) => s.replace(/[-_]+/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());

// Group every file into  folder -> (number -> slot).
const groups = new Map();
const slotFor = (folder, num) => {
  if (!groups.has(folder)) groups.set(folder, new Map());
  const m = groups.get(folder);
  if (!m.has(num)) m.set(num, { num });
  return m.get(num);
};
for (const [p, m] of Object.entries(imageMods)) { const s = slotFor(folderOf(p), numOf(p)); s.image = m; if (!s.label) s.label = labelOf(p); }
for (const [p, m] of Object.entries(gifMods))   { const s = slotFor(folderOf(p), numOf(p)); s.gif = m;   if (!s.label) s.label = labelOf(p); }
for (const [p, m] of Object.entries(videoMods)) { const s = slotFor(folderOf(p), numOf(p)); s[p.endsWith('.webm') ? 'webm' : 'mp4'] = m; if (!s.label) s.label = labelOf(p); }

// Resolve the configured project list into ordered sections (skipping empties).
const sections = [];
for (const entry of projects) {
  const folder = typeof entry === 'string' ? entry : entry.folder;
  const title = (typeof entry === 'string' ? undefined : entry.title) ?? titleCase(folder);
  const g = groups.get(folder);
  if (!g || g.size === 0) continue;
  const items = [...g.values()].sort((a, b) => a.num - b.num);
  // Pre-render an optimized poster for any video slot that ships a same-numbered image.
  for (const s of items) {
    if ((s.webm || s.mp4) && s.image) {
      s.poster = (await getImage({ src: s.image, format: 'webp', quality: 60, width: 1280 })).src;
    }
  }
  sections.push({ folder, title, items });
}

// Mark the first still image (the LCP candidate at the top of the column) so it
// loads eagerly at high priority instead of being deferred like the rest.
outer: for (const section of sections) {
  for (const s of section.items) {
    if (!s.webm && !s.mp4 && !s.gif && s.image) { s.priority = true; break outer; }
  }
}

// Responsive widths, capped at each image's native width so nothing is upscaled.
// `sizes` mirrors the right-column content width (see index.astro layout).
const RESPONSIVE_WIDTHS = [640, 960, 1280, 1600, 2048, 2880];
const RESPONSIVE_SIZES = '(max-width: 1023px) calc(100vw - 32px), calc(100vw - 684px)';
const widthsFor = (img) => [...RESPONSIVE_WIDTHS.filter((w) => w < img.width), img.width];

// Closing line rendered as the last item of the list, so it inherits the same
// 32px gap that separates the projects instead of hanging below the column's
// leftover height.
const { outro } = Astro.props;
---

<div class="projects">
    {sections.map((section) => (
        <section class="project">
            <h2 class="project-label">{section.title}</h2>
            <div class="images">
                {section.items.map((s) => {
                    const alt = s.label ? `${section.title} – ${s.label}` : `${section.title} – ${s.num}`;
                    if (s.webm || s.mp4) return (
                        <video
                            class="project-image"
                            width={s.image?.width ?? 1920}
                            height={s.image?.height ?? 1080}
                            poster={s.poster}
                            loop
                            muted
                            playsinline
                            preload="none"
                            aria-label={alt}
                            data-lazy-video
                        >
                            {s.webm && <source data-src={s.webm} type="video/webm" />}
                            {s.mp4 && <source data-src={s.mp4} type="video/mp4" />}
                        </video>
                    );
                    if (s.gif) return (
                        <img
                            class="project-image"
                            src={s.gif.src}
                            width={s.gif.width}
                            height={s.gif.height}
                            alt={alt}
                            loading="lazy"
                            decoding="async"
                        />
                    );
                    return (
                        <Picture
                            src={s.image}
                            formats={['avif', 'webp']}
                            widths={widthsFor(s.image)}
                            sizes={RESPONSIVE_SIZES}
                            quality={78}
                            loading={s.priority ? 'eager' : 'lazy'}
                            fetchpriority={s.priority ? 'high' : 'auto'}
                            decoding="async"
                            alt={alt}
                            class="project-image"
                        />
                    );
                })}
            </div>
        </section>
    ))}
    {outro && (
        <p class="projects-outro">
            {outro.before}<button
                type="button"
                class="projects-outro-link"
                data-reachout-location="projects_end"
            >{outro.link}</button>{outro.after}
        </p>
    )}
</div>

<script>
    // Lazy-load any video: no network until it nears the viewport, then autoplay muted.
    const videos = document.querySelectorAll('video[data-lazy-video]');
    if (videos.length) {
        const io = new IntersectionObserver((entries, obs) => {
            for (const entry of entries) {
                if (!entry.isIntersecting) continue;
                const video = entry.target as HTMLVideoElement;
                video.querySelectorAll<HTMLSourceElement>('source[data-src]').forEach((source) => {
                    source.src = source.dataset.src ?? '';
                    source.removeAttribute('data-src');
                });
                video.load();
                video.play().catch(() => {});
                obs.unobserve(video);
            }
        }, { rootMargin: '300px 0px' });
        videos.forEach((v) => io.observe(v));
    }
</script>

<style>
.projects {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
}

.project {
    width: 100%;
    max-width: 100%;
}

.project-label {
    font-size: 16px;
    font-weight: 400;
    line-height: 20px;
    color: #000000;
    margin-bottom: 6px;
}

/* Same type as .project-label so the closing line reads as part of the column,
   but set apart from the last project so it reads as a closing note rather than
   another project's caption. The projects themselves stay flush. */
.projects-outro {
    font-size: 16px;
    font-weight: 400;
    line-height: 20px;
    color: #000000;
    text-wrap: pretty;
    padding-bottom: 28px;
}

.projects-outro-link {
    font: inherit;
    color: inherit;
    background: none;
    border: none;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
    transition: color 0.15s ease-in-out;
}

.projects-outro-link:hover {
    color: #7a7a7a;
}

.projects-outro-link:focus-visible {
    outline: 2px solid #1e1e1e;
    outline-offset: 2px;
}

.images {
    width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.project-image {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0;
    padding: 0;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 8px;
}
</style>
