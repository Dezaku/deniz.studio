---
import { Image } from 'astro:assets';
import adamPFP from '../images/adam_pfp.png';
import januPFP from '../images/janu_pfp.jpg';

const testimonials = [
  {
    text: `"Deniz helped turn an open ended logo brief into a <strong>clear visual direction</strong>. I came in without a strong idea of what I wanted, and his explorations <strong>helped us land on something distinctive</strong> that I'm <strong>really happy</strong> with."`,
    author: "Adam Smielewski - Scalerail",
    img: adamPFP,
  },
  {
    text: `"Deniz helped us fixing our website. He <strong>really thought things through</strong>, made good recommendations and did it all in a very short space of time. <strong>We had a tight deadline and he delivered</strong>. Thank you, Deniz!"`,
    author: "Janu Lingeswaran - Feather Flow",
    img: januPFP,
  },
];
---

<div class="testimonials-outer" data-testimonials>
  <div class="testimonials-viewport">
    {testimonials.map((t, i) => (
      <div class="testimonial-slide" data-index={i} data-active={i === 0}>
        <div class={`testimonial-text${i === 0 ? ' testimonial-text--adam' : ''}`} set:html={t.text} />
        <div class="testimonial-author-row">
          <div class="testimonial-pfp-wrap">
            <Image src={t.img} class="testimonial-pfp" alt={t.author} width={28} height={28} />
          </div>
          <div class="testimonial-author">{t.author}</div>
        </div>
      </div>
    ))}
  </div>
  <div class="testimonial-dots">
    {testimonials.map((_, i) => (
      <button
        class="tdot"
        data-index={i}
        data-active={i === 0}
        aria-label={`Go to testimonial ${i + 1}`}
      ></button>
    ))}
  </div>
</div>

<script>
  (function () {
    const CONFIG = { interval: 7000 };
    const outer = document.querySelector('[data-testimonials]');
    if (!outer) return;
    const slides = outer.querySelectorAll('.testimonial-slide');
    const dots = outer.querySelectorAll('.tdot');
    if (!slides.length) return;
    let current = 0;
    let timer = null;

    function goTo(index) {
      if (index === current) return;
      slides[current].dataset.active = 'false';
      dots[current].dataset.active = 'false';
      current = index;
      slides[current].dataset.active = 'true';
      dots[current].dataset.active = 'true';
      resetTimer();
    }

    function advance() { goTo((current + 1) % slides.length); }
    function resetTimer() { clearInterval(timer); timer = setInterval(advance, CONFIG.interval); }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        goTo(parseInt(dot.dataset.index));
      });
    });

    resetTimer();
  })();
</script>

<style>
  .testimonials-outer {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 18px;
    width: 474px;
  }

  .testimonials-viewport {
    display: grid;
  }

  .testimonial-slide {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }

  .testimonial-slide[data-active='true'] {
    opacity: 1;
    visibility: visible;
  }

  .testimonial-text {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.005em;
    color: #1e1e1e;
    margin-bottom: 8px;
    text-wrap: pretty;
  }

  .testimonial-text :global(strong) {
    font-weight: 520;
  }

  .testimonial-author-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: -1px;
  }

  .testimonial-pfp-wrap {
    width: 28px;
    height: 28px;
    border-radius: 100px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .testimonial-pfp {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-author {
    font-size: 15px;
    font-weight: 450;
    line-height: 1.5;
    color: #1e1e1e;
    text-wrap: pretty;
  }

  .testimonial-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 100%;
  }

  @media (max-width: 1023px) {
    .testimonials-outer {
      width: auto;
      margin: 0 auto;
      gap: 10px;
      max-width: 474px;
    }

    .testimonial-text {
      text-align: center;
    }

    .testimonial-author-row {
      justify-content: center;
    }
  }

  .tdot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    border: none;
    padding: 0;
    cursor: pointer;
    background-color: rgba(30, 30, 30, 0.25);
    transition: background-color 0.3s ease;
  }

  .testimonial-text--adam {
    letter-spacing: -0.035em;
  }

  .tdot[data-active='true'] {
    background-color: rgba(30, 30, 30, 0.75);
  }
</style>
