---
import { Image } from 'astro:assets';
import adamPFP from '../images/adam_pfp.png';
import januPFP from '../images/janu_pfp.jpg';

const testimonials = [
  {
    text: `Deniz helped turn an open ended logo brief into a <strong>clear visual direction</strong>. I came in without a strong idea of what I wanted, and his explorations <strong>helped us land on something distinctive</strong> that I'm <strong>really happy</strong> with.`,
    author: "Adam Smielewski - Scalerail",
    img: adamPFP,
  },
  {
    text: `Deniz helped us fixing our website. He <strong>really thought things through</strong>, made good recommendations and did it all in a very short space of time. <strong>We had a tight deadline and he delivered</strong>. Thank you, Deniz!`,
    author: "Janu Lingeswaran - FeatherFlow",
    img: januPFP,
  },
];
---

<div class="testimonials-outer" data-testimonials>
  <div class="testimonials-viewport" data-viewport>
    {testimonials.map((t, i) => (
      <div class="testimonial-slide" data-index={i}>
        <div class={`testimonial-text${i === 0 ? ' testimonial-text--adam' : ''}`} set:html={t.text} />
        <div class="testimonial-author-row">
          <div class="testimonial-pfp-wrap">
            <Image src={t.img} class="testimonial-pfp" alt={t.author} width={28} height={28} />
          </div>
          <div class="testimonial-author">{t.author}</div>
        </div>
      </div>
    ))}
  </div>
  <div class="testimonial-dots">
    {testimonials.map((_, i) => (
      <button
        class="tdot"
        data-index={i}
        data-active={i === 0}
        aria-label={`Go to testimonial ${i + 1}`}
      ></button>
    ))}
  </div>
</div>

<script>
  (function () {
    const outer = document.querySelector('[data-testimonials]');
    if (!outer) return;
    const viewport = outer.querySelector('[data-viewport]');
    const slides = outer.querySelectorAll('.testimonial-slide');
    const dots = outer.querySelectorAll('.tdot');
    if (!slides.length) return;

    var current = 0;
    var ticking = false;

    function sync() {
      var i = Math.round(viewport.scrollLeft / viewport.clientWidth);
      if (i < 0) i = 0;
      if (i >= slides.length) i = slides.length - 1;
      current = i;
      dots.forEach(function (d) {
        d.dataset.active = parseInt(d.dataset.index) === i ? 'true' : 'false';
      });
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var i = parseInt(dot.dataset.index);
        current = i;
        viewport.scrollTo({ left: i * viewport.clientWidth, behavior: 'smooth' });
      });
    });

    sync();

    var autoplay = setInterval(function () {
      current = (current + 1) % slides.length;
      viewport.scrollTo({ left: current * viewport.clientWidth, behavior: 'smooth' });
    }, 6000);

    var resetAutoplay = function () {
      clearInterval(autoplay);
      autoplay = setInterval(function () {
        current = (current + 1) % slides.length;
        viewport.scrollTo({ left: current * viewport.clientWidth, behavior: 'smooth' });
      }, 6000);
    };

    viewport.addEventListener('scroll', function () {
      if (!ticking) {
        window.requestAnimationFrame(function () {
          sync();
          ticking = false;
        });
        ticking = true;
      }
      resetAutoplay();
    }, { passive: true });
  })();
</script>

<style>
  .testimonials-outer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    width: 100%;
    justify-content: center;
  }

  .testimonials-viewport {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    width: 492px;
  }

  .testimonials-viewport::-webkit-scrollbar {
    display: none;
  }

  .testimonial-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .testimonial-text {
    font-size: 16px;
    font-weight: 450;
    line-height: 1.5;
    letter-spacing: 0;
    color: #1e1e1e;
    margin-bottom: 0px;
    text-wrap: pretty;
    text-align: center;
  }

  .testimonial-text :global(strong) {
    font-weight: 550;
  }

  .testimonial-author-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 10px;
  }

  .testimonial-pfp-wrap {
    width: 28px;
    height: 28px;
    border-radius: 100px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .testimonial-pfp {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-author {
    font-size: 15px;
    font-weight: 450;
    line-height: 1.5;
    color: #1e1e1e;
    text-wrap: pretty;
  }

  .testimonial-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 100%;
  }

  @media (max-width: 1023px) {
    .testimonials-outer {
      width: 100%;
      margin: 0 auto;
      gap: 10px;
      max-width: none;
    }

    .testimonials-viewport {
      width: 100%;
      max-width: 492px;
      margin: 0 auto;
    }

    .testimonial-text {
      text-align: center;
    }

    .testimonial-author-row {
      justify-content: center;
    }
  }

  .tdot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    border: none;
    padding: 0;
    cursor: pointer;
    background-color: rgba(30, 30, 30, 0.25);
    transition: background-color 0.3s ease;
  }

  .testimonial-text--adam {
    letter-spacing: 0em;
  }

  .tdot[data-active='true'] {
    background-color: rgba(30, 30, 30, 0.75);
  }
</style>
