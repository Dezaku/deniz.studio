---
import BaseHead from '../../components/BaseHead.astro'
import HomePage from '../../components/HomePage.astro'
import type { HomeStrings } from '../../components/HomePage.astro'
import { homeJsonLd } from '../../data/seo'

const t: HomeStrings = {
	badge: '1 PROJEKT-SLOT FREI',
	headline: 'Design-Partner für Early-Stage-Startups',
	subheadline: 'Brand Identity und Landing Pages für Gründer, die vom ersten Tag an ernst genommen werden. Branding & Webdesign aus Wiesbaden – unkomplizierte Kommunikation über Slack.',
	ctaLabel: 'Anfrage senden',
	xLabel: 'Mein X-Profil',
	nav: { email: 'e-mail', cal: 'cal', telegram: 'telegram' },
	footer: {
		imprint: 'Impressum',
		privacy: 'Datenschutz',
		photography: 'Fotografie',
		lang: { label: 'English', href: '/' },
	},
};
---

<html lang="de">
	<head>
		<BaseHead
			title="deniz.studio — Branding & Webdesign für Startups | Wiesbaden"
			description="Design-Partner für Startups: Brand Identity und Landing Pages, mit denen Gründer vom ersten Tag an seriös auftreten. Webdesign aus Wiesbaden – deutschlandweit & remote."
			path="/de/"
			hreflang
			jsonLd={homeJsonLd('de')}
		/>
	</head>
	<body>
		<HomePage t={t} lang="de" />
	</body>
</html>
