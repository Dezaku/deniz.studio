---
import BaseHead from '../components/BaseHead.astro'
import HomePage from '../components/HomePage.astro'
import type { HomeStrings } from '../components/HomePage.astro'
import { homeJsonLd } from '../data/seo'

const t: HomeStrings = {
	badge: '1 PROJECT SLOT OPEN',
	headline: 'Design partner for early-stage startups',
	subheadline: 'Brand identity and landing pages for founders who need to be taken seriously from day one. Simple Slack Communication.',
	ctaLabel: 'Reach Out',
	xLabel: 'visit my X',
	nav: { email: 'email', cal: 'cal', telegram: 'telegram' },
	projectsOutro: {
		before: 'You already scrolled through all my showcased work, ',
		link: 'reach out',
		after: " and let's work together.",
	},
	footer: {
		imprint: 'Imprint',
		privacy: 'Privacy',
		photography: 'Photography',
	},
};
---

<html lang="en">
	<head>
		<BaseHead
			title="deniz.studio — Brand Identity & Landing Pages for Startups"
			description="Design partner for early-stage startups. Brand identity and landing pages that make founders look credible from day one. Based in Wiesbaden, working worldwide."
			path="/"
			hreflang
			jsonLd={homeJsonLd('en')}
		/>
	</head>
	<body>
		<HomePage t={t} lang="en" />
	</body>
</html>
