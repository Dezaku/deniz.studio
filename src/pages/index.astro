---
import Projects from '../components/Projects.astro'
import Testimonials from '../components/Testimonials.astro'
import ReachOutForm from '../components/ReachOutForm'
import { Image } from 'astro:assets';
import figmaSVG from '../../public/figma.svg'
import mePFP from '../images/me.jpg'

const recentCaseStudyHref = 'https://www.figma.com/proto/JLxOhrF9QYq5sWpNBvDvXn/deniz.studio---Portfolio?content-scaling=fixed&node-id=19-106&p=f&scaling=min-zoom&starting-point-node-id=19:106&t=ZeVXUQBxl8rfgWIb-0&viewport=-112,304,0.12';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon light.png" media="(prefers-color-scheme: light)" />
		<link rel="icon" type="image/png" href="/favicon dark.png" media="(prefers-color-scheme: dark)" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="stylesheet" href="style.css">
		<title>deniz.studio</title>
		<meta property="og:title" content="deniz.studio"/>
    <meta property="og:url" content="https://deniz.studio"/>
    <meta property="og:image" content="https://deniz.studio/og-image.png"/>
    <meta property="og:image:width" content="1200"/>
    <meta property="og:image:height" content="630"/>
    <meta property="og:image:type" content="image/png"/>
    <meta property="og:description"
          content="Deniz is a designer nased in Wiesbaden, Germany creating modern and premium designs that elevate brands and engage audiences."/>
    <meta property="og:type" content="website"/>
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="deniz.studio"/>
    <meta name="twitter:description" content="Deniz is a designer nased in Wiesbaden, Germany creating modern and premium designs that elevate brands and engage audiences."/>
    <meta name="twitter:image" content="https://deniz.studio/og-image.png"/>
		<script is:inline>
			function updateFavicon() {
				const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const favicon = document.querySelector('link[rel="icon"]');
				if (favicon && 'href' in favicon) {
					favicon.href = isDark ? '/favicon dark.png' : '/favicon light.png';
				}
			}

			updateFavicon();
			window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', updateFavicon);
		</script>
		<script is:inline
    src="https://cdn.databuddy.cc/databuddy.js"
   data-client-id="u3DUg2DzSoaD6s6Oloc8e"
    data-track-hash-changes="true"
    data-track-attributes="true"
    data-track-outgoing-links="true"
    data-track-interactions="true"
    data-track-engagement="true"
    data-track-scroll-depth="true"
    data-track-exit-intent="true"
    data-track-bounce-rate="true"
    data-track-web-vitals="true"
    data-track-errors="true"
    data-enable-batching="true"
    crossorigin="anonymous"
    async
  ></script>
		<script is:inline>
			const track = async (eventName, properties) => {
				if (typeof window === 'undefined') return;
				const tracker = window.db?.track || window.databuddy?.track;
				if (!tracker) return;
				try { await tracker(eventName, properties); } catch (e) {
					console.log('Tracking: Failed to send event', e.message);
				}
			};

			document.addEventListener('DOMContentLoaded', function() {
				const navEmail = document.getElementById('nav-email');
				if (navEmail) {
					navEmail.addEventListener('click', function() {
						track('mail_clicked', {
							timestamp: new Date().toISOString(),
							page: window.location.pathname
						});
						window.location.href = 'mailto:mail@deniz.studio';
					});
				}

				const navTelegram = document.getElementById('nav-telegram');
				if (navTelegram) {
					navTelegram.addEventListener('click', function() {
						track('telegram_clicked', {
							url: 'https://t.me/denizdoingstuff',
							timestamp: new Date().toISOString(),
							page: window.location.pathname
						});
					});
				}

				const navTwitter = document.getElementById('nav-twitter');
				if (navTwitter) {
					navTwitter.addEventListener('click', function() {
						track('twitter_clicked', {
							url: 'https://x.com/denizdoingstuff',
							timestamp: new Date().toISOString(),
							page: window.location.pathname
						});
					});
				}

				const caseStudyBtn = document.getElementById('caseStudyBtn');
				if (caseStudyBtn) {
					caseStudyBtn.addEventListener('click', function() {
						track('casestudy_clicked', {
							timestamp: new Date().toISOString(),
							page: window.location.pathname
						});
					});
				}
			});
		</script>
	</head>
	<body>
		<div class="container">
			<div class="content-wrapper">
				<div class="left-column">

					<header class="hero-header">
						<div class="nav-row">
							<a href="/" class="site-logo">deniz.studio</a>
							<nav class="nav-links">
								<span class="nav-link email-link" id="nav-email">
									email
									<span class="email-tooltip">mail@deniz.studio</span>
								</span>
								<a class="nav-link" id="nav-telegram" href="https://t.me/denizdoingstuff" target="_blank">telegram</a>
								<a class="nav-link" id="nav-twitter" href="https://x.com/denizdoingstuff" target="_blank">x</a>
							</nav>
						</div>
					</header>

					<div class="main">
						<div class="title-cta">
							<div class="titletext">
								<div class="headline-wrap">
									<h1 class="hero-headline">Good design, better business</h1>
								</div>
								<div class="subheadline-wrap">
									<p class="hero-subheadline">You bring the vision.<br />I create designs that make you strive.</p>
								</div>
							</div>
							<div class="buttons">
								<div class="buttons-inner">
									<div class="cta-col">
										<button class="cta" id="reachOutBtn">
											<Image quality={100} src={mePFP} class="cta-pfp" alt="Deniz" width={200} height={200}/>
											<div class="cta-label">Reach Out</div>
										</button>
									</div>
									<a
										class="cta-case-study"
										href={recentCaseStudyHref}
										target="_blank"
										rel="noopener noreferrer"
										id="caseStudyBtn"
									>
										<Image quality={100} src={figmaSVG} class="figma-icon" alt="" width={54} height={80}/>
										<span>view recent case study</span>
									</a>
								</div>
							</div>
						</div>
					</div>

					<div class="bottom-content">
						<Testimonials />
						<div class="links">
							<a href="/imprint">Imprint</a>
							<a href="/privacy">Privacy</a>
							<a href="https://photo.deniz.studio" target="_blank">Photography</a>
						</div>
					</div>

				</div>

				<div class="right-column">
					<Projects />
				</div>
			</div>
		</div>

		<div class="mobile-links">
			<div class="links">
				<a href="/imprint">Imprint</a>
				<a href="/privacy">Privacy</a>
				<a href="https://photo.deniz.studio" target="_blank">Photography</a>
			</div>
		</div>

		<ReachOutForm client:load />
	</body>
</html>

<style>
	@font-face {
		font-family: 'General Sans';
		src: url('/fonts/GeneralSans-Variable.ttf') format('truetype');
		font-weight: 200 700;
		font-style: normal;
		font-display: swap;
	}

*, *::before, *::after {
  box-sizing: border-box;
  font-family: "General Sans", sans-serif;
}

* {
  margin: 0;
}

@media (prefers-reduced-motion: no-preference) {
  html {
    interpolate-size: allow-keywords;
  }
}

body {
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

img, picture, video, canvas, svg {
  display: block;
  max-width: 100%;
}

input, button, textarea, select {
  font: inherit;
}

a {
  color: inherit;
  font-size: 14px;
}

p, h1, h2, h3, h4, h5, h6 {
  overflow-wrap: break-word;
}

p {
  text-wrap: pretty;
  color: #1e1e1e;
}

h1, h2, h3, h4, h5, h6 {
  text-wrap: balance;
  color: #1e1e1e;
}

#root, #__next {
  isolation: isolate;
}

.container {
  width: 100%;
  max-width: none;
  margin: 0;
  padding: 0;
  min-height: 100vh;
}

.content-wrapper {
  display: flex;
  width: 100%;
  margin: 0;
  padding: 0;
  min-height: 100vh;
}

.left-column {
  width: 540px;
  flex-shrink: 0;
  padding: 28px 22px 28px 44px;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
}

.hero-header {
  width: 100%;
  flex-shrink: 0;
}

.nav-row {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 30px;
  width: 100%;
}

.nav-links {
  display: flex;
  align-items: start;
  gap: 24px;
}

.nav-link {
  font-size: 14px;
  font-weight: 450;
  line-height: 18px;
  color: #000000;
  cursor: pointer;
  text-decoration: none;
  background: none;
  border: none;
  padding: 0;
  transition: color 0.15s ease-in-out;
}

.nav-link:hover {
  color: #7a7a7a;
}

.email-link {
  position: relative;
}

.email-tooltip {
  position: absolute;
  left: 50%;
  top: 100%;
  transform: translateX(-50%);
  margin-top: 6px;
  padding: 6px 10px;
  font-size: 12px;
  line-height: 1.2;
  white-space: nowrap;
  color: #1e1e1e;
  background-color: #ffffff;
  border: 1px solid rgba(30, 30, 30, 0.14);
  border-radius: 6px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.15s ease, visibility 0.15s ease;
  z-index: 10;
}

.email-link:hover .email-tooltip {
  opacity: 1;
  visibility: visible;
}

.site-logo {
  flex: 1;
  font-size: 16px;
  font-weight: 520;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: #1e1e1e;
  text-decoration: none;
  transition: color 0.15s ease-in-out;
}

.site-logo:hover {
  color: #7a7a7a;
}

.main {
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 100%;
  min-height: 0;
}

.title-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
  width: 100%;
}

.titletext {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  width: 100%;
}

.headline-wrap {
  padding-bottom: 6px;
}

.headline-wrap {
  padding-bottom: 2.8px;
}

.hero-headline {
  font-size: 28px;
  font-weight: 550;
  line-height: 1.3;
  letter-spacing: -0.02em;
  text-align: center;
  text-wrap: pretty;
  color: #1e1e1e;
}

.subheadline-wrap {
  max-width: 318px;
}

.hero-subheadline {
  font-size: 15px;
  font-weight: 450;
  line-height: 1.55;
  text-align: center;
  text-wrap: pretty;
  color: #1e1e1e;
}

.buttons {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 12px;
  width: 100%;
}

.buttons-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: flex-start;
  gap: 8px;
  width: 100%;
}

.cta-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: fit-content;
  background-color: #732dff;
  color: #ffffff;
  padding: 6px 16px 6px 6px;
  border-radius: 100px;
  border: 1px solid rgba(0, 0, 0, 0.05);
  box-shadow: inset 0px -1px 12.4px -4px rgba(255, 255, 255, 0.75);
  cursor: pointer;
  transition: background-color 0.15s ease-in-out, border-color 0.15s ease-in-out;
}

.cta:hover {
  background-color: #5a1ce0;
  border-color: rgba(0, 0, 0, 0.05);
}

.cta-label {
  font-size: 14px;
  font-weight: 500;
  line-height: 1.5;
  color: #ffffff;
}

.cta-pfp {
  width: 28px;
  height: 28px;
  border-radius: 100px;
  flex-shrink: 0;
  object-fit: cover;
}

.cta-case-study {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  flex-shrink: 0;
  background-color: #ffffff;
  color: #1e1e1e;
  padding: 8px 14px 8px 16px;
  border-radius: 100px;
  border: 1px solid rgba(30, 30, 30, 0.14);
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  text-decoration: none;
  font-weight: 500;
  font-size: 14px;
  line-height: 1.2;
  white-space: nowrap;
  transition: background-color 0.15s ease-in-out, border-color 0.15s ease-in-out, color 0.15s ease-in-out;
}

.cta-case-study:hover {
  color: #1e1e1e;
  background-color: #fafafa;
  border-color: rgba(30, 30, 30, 0.22);
}

.cta-case-study:focus-visible {
  outline: 2px solid #732dff;
  outline-offset: 2px;
}

.figma-icon {
  width: 14px;
  height: auto;
  flex-shrink: 0;
}

.bottom-content {
  flex-shrink: 0;
  width: fit-content;
  padding-top: 16px;
}

.links {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
  margin-top: 22px;
  max-width: 650px;
  opacity: 0.6;
  width: 100%;
}

.links a {
  font-size: 10px;
  font-weight: 400;
  line-height: 1.3;
  color: #000000;
  text-decoration: underline;
  text-underline-offset: auto;
}

.links a:hover {
  color: #7a7a7a;
}

.right-column {
  flex: 1;
  min-width: 0;
  padding: 28px 22px 0 22px;
  margin: 0;
  width: 100%;
  max-width: 100%;
  overflow-x: visible;
  box-sizing: border-box;
}

.right-column .projects {
  margin: 0;
  padding: 0;
  width: 100%;
  max-width: 100%;
  display: block;
}

.projects {
  width: 100%;
  height: 100%;
}

.mobile-links {
  display: none;
}

@media (max-width: 1023px) {
  body {
    justify-content: flex-start;
    align-items: stretch;
  }

  .content-wrapper {
    flex-direction: column;
  }

  .left-column {
    width: 100%;
    height: auto;
    min-height: 0;
    position: static;
    padding: 24px 16px;
    overflow-y: visible;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0;
  }

  .hero-header {
    margin-bottom: 32px;
  }

  .nav-links {
    gap: 14px;
  }

  .nav-row {
    padding: 0 4px;
  }

  .nav-link {
    font-size: 14px;
  }

  .main {
    flex: 0 0 auto;
    display: block;
    justify-content: flex-start;
    min-height: 0;
    margin-bottom: 8px;
  }

  .bottom-content {
    padding-top: 32px;
    margin-top: 0;
    width: 100%;
  }

  .title-cta {
    align-items: stretch;
    gap: 24px;
  }

  .titletext {
    align-items: center;
    text-align: center;
    gap: 10px;
  }

  .headline-wrap {
    padding-bottom: 0;
  }

  .hero-headline {
    padding-bottom: 0;
    margin-bottom: 0;
    margin-top: 24px;
  }

  .subheadline-wrap {
    max-width: none;
  }

  .hero-subheadline {
    text-align: center;
    max-width: none;
    line-height: 1.4;
  }

  .buttons {
    align-items: center;
    justify-content: center;
  }

  .buttons-inner {
    flex-direction: row;
    align-items: center;
    gap: 8px;
    justify-content: center;
  }

  .cta-col {
    width: auto;
    align-items: center;
  }

  .cta-case-study {
    white-space: nowrap;
  }

  .right-column {
    padding: 0 16px 24px;
    margin-top: 24px;
  }

  .left-column .links {
    display: none;
  }

  .mobile-links {
    display: block;
    width: 100%;
    padding: 0 16px 40px;
    text-align: center;
  }

  .mobile-links .links {
    justify-content: center;
    margin: 0;
    padding: 0;
  }

}

@media (max-width: 480px) {
  .left-column {
    padding: 18px 14px;
  }

  .nav-row {
    gap: 14px;
  }

  .nav-links {
    gap: 10px;
  }

  .nav-link {
    font-size: 13px;
  }

  .buttons {
    align-items: center;
    gap: 8px;
  }

  .links {
    gap: 12px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .email-tooltip {
    transition: none;
  }
}
</style>
